{
  "manifest_version": 3,
  "name": "Private Translator (LM Studio)",
  "version": "0.0.1",
  "description": "Translate selected text using local LM Studio.",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:1234/*",
    "http://localhost:1234/*",
    "http://127.0.0.1:5005/*",
    "http://localhost:5005/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "private-translator@example.com"
    }
  }
}
